# ─── Proxy listener ──────────────────────────────────────────────
PORT=8080
# Use "wss" behind a reverse proxy (nginx/caddy) terminating TLS.

# ─── Upstream Monero Stratum pool ────────────────────────────────
# Examples:
#   pool.supportxmr.com:3333    (no TLS)
#   gulf.moneroocean.stream:10128 (TLS)
POOL_HOST=pool.supportxmr.com
POOL_PORT=3333
POOL_TLS=false

# Wallet that receives mined XMR (set by admin in Lovable Cloud platform_config)
# This is a fallback if the proxy can't fetch it from Supabase.
POOL_WALLET=YOUR_XMR_WALLET_ADDRESS_HERE
POOL_PASSWORD=x
WORKER_NAME=shrimine-web

# ─── Supabase (Lovable Cloud) ────────────────────────────────────
# Used to validate user JWTs and read platform_config.
SUPABASE_URL=https://klmfqnxiuzpeditibzhy.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtsbWZxbnhpdXpwZWRpdGliemh5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI5NTY4NDgsImV4cCI6MjA4ODUzMjg0OH0.AsPQ_QWeQ9VkJP7tOZCT5Da0Z9GdCD0BpuWU5yGTQ8s

# ─── Behavior ────────────────────────────────────────────────────
# Set to "true" to require a valid Supabase JWT (sent by browser as ?token=...).
# Set to "false" for quick public testing.
REQUIRE_AUTH=true

# Platform fee percent (0–100). Routed via pool worker name suffix for accounting.
PLATFORM_FEE=2
