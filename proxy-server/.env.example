# ─── Proxy listener ──────────────────────────────────────────────
PORT=8080
# Use "wss" behind nginx terminating TLS.

# ─── Upstream Monero Stratum pool (fallback if Supabase config missing) ───
POOL_HOST=pool.supportxmr.com
POOL_PORT=3333
POOL_TLS=false

# Wallet that receives mined XMR (admin overrides via platform_config)
POOL_WALLET=YOUR_XMR_WALLET_ADDRESS_HERE
POOL_PASSWORD=x
WORKER_NAME=shrimine-web

# ─── Supabase (Lovable Cloud) ────────────────────────────────────
SUPABASE_URL=https://klmfqnxiuzpeditibzhy.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtsbWZxbnhpdXpwZWRpdGliemh5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI5NTY4NDgsImV4cCI6MjA4ODUzMjg0OH0.AsPQ_QWeQ9VkJP7tOZCT5Da0Z9GdCD0BpuWU5yGTQ8s

# REQUIRED: service-role key — used to insert real shares + update sessions.
# Get this from Lovable Cloud → Backend → Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=PASTE_SERVICE_ROLE_KEY_HERE

# ─── Behavior ────────────────────────────────────────────────────
REQUIRE_AUTH=true
PLATFORM_FEE=2

# ─── xmrig ───────────────────────────────────────────────────────
# Path to native xmrig binary on the VPS. Install with:
#   curl -L https://github.com/xmrig/xmrig/releases/download/v6.22.0/xmrig-6.22.0-linux-static-x64.tar.gz | tar xz
#   sudo mv xmrig-*/xmrig /usr/local/bin/xmrig
XMRIG_BIN=xmrig
# Each session gets a unique HTTP API port starting from this base.
XMRIG_API_BASE_PORT=50000
